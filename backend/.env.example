# ── ASTRAM Backend Environment Variables ──
# Copy this file to .env and fill in values

# Server
PORT=8000
HOST=0.0.0.0

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,https://*.vercel.app

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Model path overrides (optional — defaults are in utils/loader.py)
# MODEL_DIR=models
# DATA_DIR=data
# OUTPUTS_DIR=outputs
